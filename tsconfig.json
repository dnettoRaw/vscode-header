{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "outDir": "out",
    "lib": [
      "es6",
      "dom"
    ],
    "types": [
      "node",
      "mocha",
      "glob"
    ],
    "noImplicitAny": true,
    "removeComments": true,
    "sourceMap": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}
